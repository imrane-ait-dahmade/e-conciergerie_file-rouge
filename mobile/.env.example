# Copie ce fichier en .env à la racine du dossier mobile (ne commite pas .env avec des secrets).
# URL du backend NestJS (sans slash final). Obligatoire : http:// ou https:// devant l’hôte
# (sinon l’URL est interprétée comme chemin relatif à Metro → http://localhost:8081/192.168…).
# Sur appareil physique : mets l’IP locale de ton PC (ex. http://192.168.1.15:3000).
# Émulateur Android vers la machine hôte : http://10.0.2.2:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google Maps (react-native-maps + PROVIDER_GOOGLE) — optionnel tant que tu ne testes pas la carte native.
# Crée des clés dans Google Cloud Console (APIs : Maps SDK for Android, Maps SDK for iOS).
# iOS et Android peuvent utiliser deux clés distinctes (restrictions par bundle / SHA-1).
# Après première config ou changement de clé : npx expo prebuild --clean puis build dev / EAS.
EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=
