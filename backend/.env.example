# ===========================================
# E-Conciergerie Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# Required variables must be set - app will not start without them.

# --- App ---
NODE_ENV=development
PORT=3000

# --- MongoDB ---
MONGODB_URL=mongodb://localhost:27017/e-conciergerie

# --- JWT (min 32 chars each, use strong random secrets in production) ---
JWT_SECRET=your-access-token-secret-at-least-32-characters-long
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-refresh-token-secret-at-least-32-characters-long
JWT_REFRESH_EXPIRES_IN=7d

# --- Frontend ---
FRONTEND_URL=http://localhost:3000

# --- Mail ---
MAIL_FROM=noreply@example.com

# --- Admin initial (optionnel) — logique dans src/users/seeds/admin.seed.ts ---
# Si ADMIN_EMAIL et ADMIN_PASSWORD sont définis, un compte admin est créé au démarrage
# (une seule fois : pas de doublon si l’email existe déjà).
# ADMIN_NOM / ADMIN_PRENOM : facultatifs ; sinon défaut "Admin" / "Système".
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=ChangeMoi123!
# ADMIN_NOM=Admin
# ADMIN_PRENOM=Plateforme
