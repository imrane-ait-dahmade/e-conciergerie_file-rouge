# ===========================================
# E-Conciergerie Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# Required variables must be set - app will not start without them.

# --- App ---
NODE_ENV=development
PORT=3000

# --- MongoDB ---
MONGODB_URL=mongodb://localhost:27017/e-conciergerie

# --- Seed démo (CLI, une commande) — orchestrateur : src/seeds/run-demo-master.ts ---
# Depuis le dossier backend : npm run seed:demo
# Prérequis : MongoDB joignable, MONGODB_URL défini (pas besoin de JWT pour le script).

# --- JWT (min 32 chars each, use strong random secrets in production) ---
JWT_SECRET=your-access-token-secret-at-least-32-characters-long
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-refresh-token-secret-at-least-32-characters-long
JWT_REFRESH_EXPIRES_IN=7d

# --- MinIO (uploads) — racine du repo : docker compose up -d ---
# Connexion MinIO (utilisée par UploadsService)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Évite la découverte de région S3 (GetBucketLocation) — recommandé pour MinIO local
MINIO_REGION=us-east-1
MINIO_BUCKET=uploads
# Base pour construire l’URL renvoyée après upload (pas pour se connecter au SDK)
MINIO_PUBLIC_URL=http://localhost:9000

# --- Frontend ---
FRONTEND_URL=http://localhost:3000

# --- Mobile (Expo) — CORS pour Expo Web / dev server Metro (défaut http://localhost:8081 dans main.ts si absent)
# MOBILE_DEV_ORIGIN=http://192.168.1.10:8081

# --- Mail ---
MAIL_FROM=noreply@example.com

# --- Comptes de démo (seed automatique au démarrage) — src/users/seeds/demo-users.seed.ts ---
# 3 utilisateurs : admin@econciergerie.ma, provider@econciergerie.ma, traveler@econciergerie.ma
# (création idempotente : pas de doublon si l’email existe déjà).

# --- Géographie démo (seed au démarrage) — src/pays/seeds/geographie-kenitra.seed.ts ---
# Maroc (MA), Kénitra, 5 quartiers — idempotent, sans variable d’environnement.

# --- Établissements démo (seed après bootstrap) — src/etablissements/seeds/demo-etablissements-kenitra.seed.ts ---
# 3 établissements à Kénitra, prestataire provider@econciergerie.ma — upsert par slug.

# --- Offres démo (etablissement_services + caractéristiques) — src/etablissement-services/seeds/demo-etablissement-services.seed.ts ---
# 9 liaisons catalogue ↔ établissements Kénitra, après domaines/services/établissements seedés.
# Carte / nearby : point de test exporté KENITRA_DEMO_MAP_CENTER dans demo-etablissements-kenitra.seed.ts
# (ex. GET /map/nearby?lat=34.261&lng=-6.5805&radiusKm=8).
