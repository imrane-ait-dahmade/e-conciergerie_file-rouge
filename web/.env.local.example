# Copier ce fichier vers .env.local (à la racine du dossier web/) puis adapter les valeurs.
# Ne commitez jamais .env.local (secrets / config machine).

# URL publique du backend NestJS (utilisée dans le navigateur pour login, signup, etc.)
# Exemple si Nest écoute sur le port 3001 et Next sur 3000 :
NEXT_PUBLIC_API_URL=http://localhost:3001

# Connexion OAuth (redirection navigateur vers l’URL du fournisseur ou route backend)
# Laisser vide tant que le backend n’expose pas les endpoints — le bouton affiche alors un message.
# NEXT_PUBLIC_OAUTH_GOOGLE_URL=https://example.com/api/auth/google
# NEXT_PUBLIC_OAUTH_APPLE_URL=https://example.com/api/auth/apple
